# BP35A1
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUD=115200
BROUTE_ID=your-broute-id
BROUTE_PASS=your-broute-password
EPAN_CACHE=epan.json

# 出力先: influx または stdout
OUTPUT=influx

# InfluxDB v2
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-influxdb-token
INFLUX_ORG=your-org
INFLUX_BUCKET=smartmeter

# タグ
METER_TAG=meter01

# ポーリング周期
POLL_POWER=10s
POLL_ENERGY=60s

# 応答待ちタイマー
GET_TIMEOUT=20s
GET_TIMEOUT_LONG=60s

# 計測日時(EDT)の解釈に使うタイムゾーン
METER_TIMEZONE=Asia/Tokyo

# ログレベル: debug | info | warn | error
LOG_LEVEL=info
